rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Server-only collections (Admin SDK bypasses rules)
    match /chat_logs/{doc} {
      allow read, write: if false;
    }
    match /knowledge_custom/{doc} {
      allow read, write: if false;
    }
    match /knowledge_pending/{doc} {
      allow read, write: if false;
    }
    match /rate_limits/{doc} {
      allow read, write: if false;
    }

    // Profiles: public read, admin write
    match /profiles/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "yeojoonsoo02@gmail.com";
    }

    // Comments: public read, authenticated create with validation
    match /comments/{doc} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 1000;
      allow update, delete: if false;
    }

    // Visitor counter: public read/write (increment only)
    match /counters/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // Portfolio: public read, admin write
    match /portfolio/{doc} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email == "yeojoonsoo02@gmail.com";
    }

    // Prompt logs: create with validation only
    match /prompt_logs/{doc} {
      allow create: if request.resource.data.question is string
        && request.resource.data.question.size() < 2000;
      allow read, update, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
