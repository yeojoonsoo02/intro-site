# Firebase 클라이언트 (브라우저 노출 정상 — Firestore Rules로 접근 제어)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# 사이트 URL (카카오 공유 등에 사용)
NEXT_PUBLIC_APP_URL=https://yeojoonsoo02.com

# Firebase Admin SDK — 서비스 어카운트 JSON 전체를 한 줄로 (서버 전용)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Gemini AI — 키 없으면 fallback URL 사용 (서버 전용 변수로 변경됨, NEXT_PUBLIC_ 제거됨)
GEMINI_API_KEY=
GEMINI_API_FALLBACK_URL=

# 챗봇 외부 webhook (질문/답변 페어 전달)
WEBSITE_CHAT_WEBHOOK_URL=

# 카카오톡 메시지 발송 (서버 전용)
KAKAO_ACCESS_TOKEN=

# 실시간 컨텍스트 (위치/식사/수면 등) 외부 API
CONTEXT_API_KEY=

# 텔레그램 알림 봇 (질문/답변 알림)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# RAG 시드 갱신 인증 — /api/rag/seed 호출용
ADMIN_SECRET=

# IndexNow (검색엔진 색인 자동 제출) — `npm run indexnow` 첫 실행 시 자동 생성됨
INDEXNOW_KEY=
INDEXNOW_ADMIN_KEY=

# 검색엔진 사이트 인증 — 발급 후 채우면 layout.tsx 메타 태그에 자동 반영
# Bing Webmaster Tools: https://www.bing.com/webmasters → "메타 태그" 인증 코드
NEXT_PUBLIC_BING_VERIFICATION=
# Yandex Webmaster: https://webmaster.yandex.com → "Meta tag" 인증 코드 (선택)
NEXT_PUBLIC_YANDEX_VERIFICATION=
